                  </Label>
                  <TextField fx:id="idField" promptText="Enter ID" style="-fx-background-color: white; -fx-background-radius: 5;" />
               </children>
            </VBox>
            
            <HBox spacing="15.0">
               <children>
                  <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                     <children>
                        <Label text="Course" textFill="#f2edc2">
                           <font>
                              <Font name="System Bold" size="12.0" />
                           </font>
                        </Label>
                        <TextField fx:id="courseField" promptText="Enter Course" style="-fx-background-color: white; -fx-background-radius: 5;" />
                     </children>
                  </VBox>
                  <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                     <children>
                        <Label text="Year" textFill="#f2edc2">
