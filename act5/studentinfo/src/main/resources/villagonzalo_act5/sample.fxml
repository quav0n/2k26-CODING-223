                  </Label>
                  <TextField fx:id="nameField" promptText="Enter Name" style="-fx-background-color: white; -fx-background-radius: 5;" />
               </children>
            </VBox>
            
            <VBox spacing="3.0">
               <children>
                  <Label text="Student ID" textFill="#f2edc2">
                     <font>
                        <Font name="System Bold" size="12.0" />
