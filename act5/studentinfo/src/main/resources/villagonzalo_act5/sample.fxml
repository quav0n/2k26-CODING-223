<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefWidth="400.0" style="-fx-border-color: #346739; -fx-border-width: 2; -fx-background-radius: 10; -fx-border-radius: 10; -fx-background-color: #F2EDC2;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="villagonzalo_act5.SampleController">
   <children>
      
      <HBox alignment="CENTER" prefHeight="50.0" style="-fx-background-color: #F2EDC2; -fx-background-radius: 10 10 0 0;">
         <children>
            <Label text="Student Information" textFill="#346739">
               <font>
                  <Font name="System Bold" size="18.0" />
